# Copy this file to bot/.env and fill in the values. (.env is gitignored; .env.example is NOT
# — never put real secrets here.) Use KEY=value with no spaces around = and no inline comments
# on the secret lines.

# --- Discord application (from https://discord.com/developers/applications) ---
DISCORD_TOKEN=               # Bot → Reset Token → copy
DISCORD_CLIENT_ID=          # General Information → Application ID
DISCORD_GUILD_ID=           # your server's id (Developer Mode → right-click server → Copy Server ID)

# Who may run admin commands. A Discord role id; when set, ONLY that role counts.
ADMIN_ROLE_ID=

# When ADMIN_ROLE_ID is blank: /setup creates this marker role, and holders of it
# (or anyone with "Manage Server") count as bot admins.
ADMIN_ROLE_NAME=Match Admin

# --- Onboarding / roles ---
LINKED_ROLE_NAME=Linked       # role granted on /link that unlocks the server
COMMANDS_CHANNEL_NAME=commands  # the only channel where slash commands work (signup via /link, match votes); chat is auto-deleted there

# --- Voice layout ---
INHOUSE_CATEGORY=Inhouse      # category name the bot creates/uses for match channels
LOBBY_CHANNEL_ID=            # the persistent Lobby voice channel id (players wait here)

# --- Website API (the bot is a client of your backend) ---
API_BASE_URL=http://localhost:4000/api   # backend base incl. /api (Railway URL in prod)
BOT_TOKEN=                    # MUST equal BOT_TOKEN configured on the backend
